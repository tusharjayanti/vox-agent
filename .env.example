# ─── LLM provider selection ───
VOXAGENT_LLM_PROVIDER=anthropic

# ─── API keys (no VOXAGENT_ prefix — standard env var names) ───
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...

# ─── Infrastructure (no VOXAGENT_ prefix) ───
POSTGRES_DSN=postgresql://voxagent:voxagent@localhost:5432/voxagent

# ─── Anthropic model selection ───
VOXAGENT_ANTHROPIC_GENERATOR_MODEL=claude-sonnet-4-6
VOXAGENT_ANTHROPIC_JUDGE_MODEL=claude-haiku-4-5-20251001

# ─── OpenAI model selection (unused in v1 — provider stub) ───
# VOXAGENT_OPENAI_GENERATOR_MODEL=gpt-4o
# VOXAGENT_OPENAI_JUDGE_MODEL=gpt-4o-mini

# ─── Gemini model selection (unused in v1 — provider stub) ───
# VOXAGENT_GEMINI_GENERATOR_MODEL=gemini-2.5-pro
# VOXAGENT_GEMINI_JUDGE_MODEL=gemini-2.5-flash

# ─── Tuning (optional, all have defaults) ───
VOXAGENT_GENERATOR_TEMPERATURE=0.3
VOXAGENT_JUDGE_TEMPERATURE=0.0
VOXAGENT_MAX_RETRIES=1
VOXAGENT_GENERATOR_MAX_TOKENS=1024

# ─── Phase 2: RAG (leave blank until Phase 2) ───
# VOYAGE_API_KEY=pa-...
# VOXAGENT_EMBEDDING_MODEL=voyage-3
# VOXAGENT_RETRIEVAL_TOP_K=3
